{
  "manifest_version": 3,
  "name": "Instagram Reels Controls",
  "version": "1.3.0",
  "description": "Video-Scrubbing und Lautstärkeregelung für Instagram Reels",
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "instagram-reels-controls@timmmy.dev",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Instagram Reels Controls"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
