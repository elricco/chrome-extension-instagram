{
  "manifest_version": 3,
  "name": "Instagram Reels Controls",
  "version": "1.0.0",
  "description": "Video-Scrubbing und Lautstärkeregelung für Instagram Reels",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
